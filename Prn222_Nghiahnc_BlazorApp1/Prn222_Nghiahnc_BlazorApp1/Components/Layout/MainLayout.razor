@inherits LayoutComponentBase

<div class="page d-flex flex-column min-vh-100">
    <NavMenu />

    <main class="flex-grow-1">
        <div class="content px-3 px-md-4 pt-3 pb-4">
            @Body
        </div>
    </main>

    <footer class="admin-footer">
        <span>&copy; @DateTime.Now.Year EventHub Admin Portal</span>
        <span>
            <i class="bi bi-shield-check text-success me-1"></i>
            Secure Admin Session
        </span>
    </footer>
</div>

<div id="blazor-error-ui" class="blazor-error-boundary">
    An unhandled error has occurred. <a href="" class="alert-link">Reload</a>
    <a class="dismiss">&#x2715;</a>
</div>
