            <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                <AuthorizeView Roles="1">
                    <Authorized>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="admin/accounts">
                                <i class="bi bi-person-x-fill me-1"></i> Account Management
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="admin/approve-organizers">
                                <i class="bi bi-person-check-fill me-1"></i> Approve Organizers
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="admin/transaction-disputes">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> Disputes
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="admin/system-settings">
                                <i class="bi bi-gear-fill me-1"></i> System Settings
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link px-3" href="admin/payment-gateways">
                                <i class="bi bi-credit-card-fill me-1"></i> Payment Gateways
                            </NavLink>
                        </li>
                        <li class="nav-item ms-lg-3">
