@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@using global::Services
@inject IUserService UserService
@inject ITransactionService TransactionService
@implements IAsyncDisposable

<nav class="navbar navbar-expand-lg navbar-vibrant sticky-top">
    <div class="container-fluid px-3 px-md-4">
        <a class="navbar-brand d-flex align-items-center gap-2" href="admin/accounts">
            <i class="bi bi-shield-check fs-5"></i>
            <span>EventHub Admin</span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#adminNavbar"
                aria-controls="adminNavbar" aria-expanded="false"
                aria-label="Toggle navigation" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="@NavMenuCssClass navbar-collapse" id="adminNavbar">
            <AuthorizeView Roles="1">
                <Authorized>
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1" href="admin/accounts"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-people-fill"></i>
                                <span>Users &amp; Organizers</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/approve-organizers"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-person-check-fill"></i>
                                <span>Approve Organizers</span>
                                <!-- Real-time badge via SignalR -->
                                @if (pendingOrganizers > 0)
                                {
                                    <span class="nav-badge">@pendingOrganizers</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/transaction-disputes"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span>Disputes</span>
                                <!-- Real-time badge via SignalR -->
                                @if (openDisputes > 0)
                                {
                                    <span class="nav-badge">@openDisputes</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/system-settings"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-gear-fill"></i>
                                <span>Settings</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/payment-gateways"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-credit-card-fill"></i>
                                <span>Payment Gateways</span>
                            </NavLink>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">
                        <!-- SignalR connection status indicator -->
                        <li class="nav-item d-none d-lg-block">
                            <span class="nav-link pe-none d-flex align-items-center gap-1"
                                  style="font-size:.72rem; opacity:.75;"
                                  title="@(hubConnected ? "Real-time notifications active" : "Connecting...")">
                                <span class="@(hubConnected ? "status-dot-online" : "status-dot-offline")"></span>
                                @(hubConnected ? "Live" : "Connecting…")
                            </span>
                        </li>

                        <li class="nav-item">
                            <span class="nav-link d-flex align-items-center gap-2 pe-none"
                                  style="opacity:.85;">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25"
                                      style="width:28px;height:28px;font-size:.75rem;font-weight:700;color:#fff;">
                                    @(context.User.Identity?.Name is { Length: > 0 } n ? char.ToUpper(n[0]).ToString() : "A")
                                </span>
                                <span class="d-none d-lg-inline">@context.User.Identity?.Name</span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1 text-danger"
                               href="/api/auth/logout">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Logout</span>
                            </a>
                        </li>
                    </ul>
                </Authorized>
                <NotAuthorized>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1" href="login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span>Login</span>
                            </NavLink>
                        </li>
                    </ul>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    // Real-time badge counts (updated via SignalR)
    private int pendingOrganizers = 0;
    private int openDisputes = 0;
    private bool hubConnected = false;

    private HubConnection? _hubConnection;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // Load initial counts from DB
        try
        {
            pendingOrganizers = UserService.GetPendingOrganizerCount();
            openDisputes      = TransactionService.GetOpenDisputeCount();
            StateHasChanged();
        }
        catch { /* Silently ignore if DB unavailable */ }

        // Connect to SignalR for real-time updates
        await ConnectSignalRAsync();
    }

    private async Task ConnectSignalRAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(Navigation.ToAbsoluteUri("/hubs/admin"))
                .WithAutomaticReconnect()
                .Build();

            // Listen: Background Worker broadcasts count changes every 30s
            _hubConnection.On<int, int>("PendingCountsUpdated", (organizers, disputes) =>
            {
                pendingOrganizers = organizers;
                openDisputes      = disputes;
                InvokeAsync(StateHasChanged);
            });

            // Listen: Organizer approved/rejected (from other admin tabs)
            _hubConnection.On<string, int>("OrganizerApproved", (_, count) =>
            {
                pendingOrganizers = count;
                InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<string, int>("OrganizerRejected", (_, count) =>
            {
                pendingOrganizers = count;
                InvokeAsync(StateHasChanged);
            });

            // Listen: Dispute resolved (from other admin tabs)
            _hubConnection.On<int, bool, int>("DisputeResolved", (_, __, count) =>
            {
                openDisputes = count;
                InvokeAsync(StateHasChanged);
            });

            _hubConnection.Reconnected += async _ =>
            {
                hubConnected = true;
                await InvokeAsync(StateHasChanged);
            };
            _hubConnection.Closed += async _ =>
            {
                hubConnected = false;
                await InvokeAsync(StateHasChanged);
            };

            await _hubConnection.StartAsync();
            hubConnected = true;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[NavMenu] SignalR connection failed: {ex.Message}");
            hubConnected = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
