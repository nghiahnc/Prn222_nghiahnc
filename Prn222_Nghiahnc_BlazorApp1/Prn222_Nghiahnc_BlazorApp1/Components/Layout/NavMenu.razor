@using Microsoft.AspNetCore.Components.Authorization
@using global::Services
@inject IUserService UserService
@inject ITransactionService TransactionService
@inject Prn222_Nghiahnc_BlazorApp1.Services.AdminSessionService Session
@implements IDisposable

<nav class="navbar navbar-expand-lg navbar-vibrant sticky-top">
    <div class="container-fluid px-3 px-md-4">
        <a class="navbar-brand d-flex align-items-center gap-2" href="admin/accounts">
            <i class="bi bi-shield-check fs-5"></i>
            <span>EventHub Admin</span>
        </a>

        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#adminNavbar"
                aria-controls="adminNavbar" aria-expanded="false"
                aria-label="Toggle navigation" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="@NavMenuCssClass navbar-collapse" id="adminNavbar">
            <AuthorizeView Roles="1">
                <Authorized>
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1" href="admin/accounts"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-people-fill"></i>
                                <span>Users &amp; Organizers</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/approve-organizers"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-person-check-fill"></i>
                                <span>Approve Organizers</span>
                                <!-- Real-time badge via SignalR -->
                                @if (pendingOrganizers > 0)
                                {
                                    <span class="nav-badge">@pendingOrganizers</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/transaction-disputes"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span>Disputes</span>
                                <!-- Real-time badge via SignalR -->
                                @if (openDisputes > 0)
                                {
                                    <span class="nav-badge">@openDisputes</span>
                                }
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/system-settings"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-gear-fill"></i>
                                <span>Settings</span>
                            </NavLink>
                        </li>
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1"
                                     href="admin/payment-gateways"
                                     Match="NavLinkMatch.Prefix">
                                <i class="bi bi-credit-card-fill"></i>
                                <span>Payment Gateways</span>
                            </NavLink>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1 align-items-lg-center">


                        <li class="nav-item">
                            <span class="nav-link d-flex align-items-center gap-2 pe-none"
                                  style="opacity:.85;">
                                <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25"
                                      style="width:28px;height:28px;font-size:.75rem;font-weight:700;color:#fff;">
                                    @(context.User.Identity?.Name is { Length: > 0 } n ? char.ToUpper(n[0]).ToString() : "A")
                                </span>
                                <span class="d-none d-lg-inline">@context.User.Identity?.Name</span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1 text-danger"
                               href="/api/auth/logout">
                                <i class="bi bi-box-arrow-right"></i>
                                <span>Logout</span>
                            </a>
                        </li>
                    </ul>
                </Authorized>
                <NotAuthorized>
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <NavLink class="nav-link d-flex align-items-center gap-1" href="login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                <span>Login</span>
                            </NavLink>
                        </li>
                    </ul>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</nav>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private int pendingOrganizers = 0;
    private int openDisputes = 0;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    protected override void OnInitialized()
    {
        Session.OnCountsChanged += RefreshCounts;
        RefreshCounts();
    }

    private void RefreshCounts()
    {
        try
        {
            pendingOrganizers = UserService.GetPendingOrganizerCount();
            openDisputes      = TransactionService.GetOpenDisputeCount();
            InvokeAsync(StateHasChanged);
        }
        catch { /* Silently ignore if DB unavailable */ }
    }

    public void Dispose()
    {
        Session.OnCountsChanged -= RefreshCounts;
    }
}
