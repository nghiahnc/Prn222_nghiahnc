@page "/admin/approve-organizers"
@attribute [Authorize(Roles = "1")]
@using Domain
@using global::Services
@inject IUserService UserService
@inject Prn222_Nghiahnc_BlazorApp1.Services.AdminSessionService Session
@rendermode InteractiveServer

<PageTitle>Approve Organizers — Admin Portal</PageTitle>

<div class="container-fluid">

    <!-- Page Title -->
    <div class="page-title-section">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="admin/accounts">Dashboard</a></li>
                <li class="breadcrumb-item active">Approve Organizers</li>
            </ol>
        </nav>
        <h4><i class="bi bi-person-check-fill text-warning me-2"></i>Approve Organizer Registrations</h4>
        <p>Review and approve or reject pending organizer account registrations.</p>
    </div>

    <!-- Summary Stats -->
    @if (allOrganizers != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon amber">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allOrganizers.Count(u => u.Status == 0))</h3>
                        <small>Pending Review</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon green">
                        <i class="bi bi-check-circle-fill"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allOrganizers.Count(u => u.Status == 1))</h3>
                        <small>Approved</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon red">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allOrganizers.Count(u => u.Status == 2))</h3>
                        <small>Rejected/Banned</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon blue">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allOrganizers.Count)</h3>
                        <small>Total Organizers</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Main Card -->
    <div class="card card-modern">
        <!-- Header with search -->
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h5 class="mb-0">
                    <i class="bi bi-hourglass-split text-warning me-2"></i>
                    Pending Registrations
                    @if (pendingOrganizers != null && pendingOrganizers.Count > 0)
                    {
                        <span class="badge rounded-pill ms-2"
                              style="background:#f59e0b;color:white;font-size:.65rem;vertical-align:middle;">
                            @pendingOrganizers.Count
                        </span>
                    }
                </h5>
            </div>
            <div class="input-group input-group-sm" style="max-width:280px;">
                <span class="input-group-text bg-light border-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" class="form-control border-0 bg-light"
                       placeholder="Search by username or email..."
                       @bind="searchTerm" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button class="input-group-text bg-light border-0 btn p-0 pe-2"
                            @onclick="() => searchTerm = string.Empty" title="Clear search">
                        <i class="bi bi-x text-muted"></i>
                    </button>
                }
            </div>
        </div>

        <!-- Alert + Confirm Modal -->
        <AdminAlert @ref="alert" />
        <ConfirmationModal @ref="confirmModal" OnConfirm="HandleConfirm" />

        <!-- Content -->
        <div class="card-body p-0">
            @if (pendingOrganizers == null)
            {
                <div class="loading-container">
                    <div class="spinner-modern"></div>
                    <span>Loading pending registrations...</span>
                </div>
            }
            else if (FilteredOrganizers.Count == 0)
            {
                <div class="empty-state">
                    @if (string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <div class="display-icon text-success">
                            <i class="bi bi-check-circle-fill"></i>
                        </div>
                        <h5>All Caught Up!</h5>
                        <p>There are no pending organizer registrations at the moment. Check back later.</p>
                    }
                    else
                    {
                        <div class="display-icon">
                            <i class="bi bi-search"></i>
                        </div>
                        <h5>No Results Found</h5>
                        <p>No pending organizers match "<strong>@searchTerm</strong>". Try a different search term.</p>
                        <button class="btn btn-outline-primary btn-sm rounded-pill mt-2"
                                @onclick="() => searchTerm = string.Empty">
                            Clear Search
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Organizer</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Registered</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in PagedOrganizers)
                            {
                                <tr>
                                    <td class="fw-bold" style="color:#9ca3af;font-size:.8rem;">
                                        #@user.Id
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-placeholder text-warning">
                                                @(string.IsNullOrEmpty(user.UserName) ? "?" : user.UserName.Substring(0, 1).ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-semibold" style="font-size:.875rem;">@user.UserName</div>
                                                <div style="font-size:.75rem;color:#9ca3af;">Organizer Account</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.Email))
                                        {
                                            <a href="mailto:@user.Email" class="text-decoration-none"
                                               style="font-size:.84rem;">
                                                <i class="bi bi-envelope me-1 text-muted"></i>@user.Email
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size:.8rem;">No email</span>
                                        }
                                    </td>
                                    <td style="font-size:.84rem;color:#6b7280;">
                                        @if (!string.IsNullOrEmpty(user.Phone))
                                        {
                                            <i class="bi bi-telephone me-1"></i>@user.Phone
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge-soft-warning">
                                            <i class="bi bi-hourglass-split me-1"></i>Pending
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <button class="btn btn-sm btn-outline-success rounded-pill px-3"
                                                    @onclick="() => Approve(user)" title="Approve this organizer">
                                                <i class="bi bi-check-lg me-1"></i>Approve
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                    @onclick="() => Reject(user)" title="Reject this organizer">
                                                <i class="bi bi-x-lg me-1"></i>Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <AdminPagination CurrentPage="currentPage" TotalPages="TotalPages" TotalCount="FilteredOrganizers.Count" PageSize="pageSize" EntityName="organizers" OnPageChanged="GoToPage" />
            }
        </div>
    </div>
</div>

@code {
    // All organizers (role=2) for stats
    private List<User>? allOrganizers;
    // Only pending ones for display
    private List<User>? pendingOrganizers;

    private AdminAlert alert = default!;
    private ConfirmationModal confirmModal = default!;
    private Func<Task>? pendingAction;

    // Session-backed state
    private string searchTerm
    {
        get => Session.OrganizerSearchTerm;
        set { Session.OrganizerSearchTerm = value; currentPage = 1; }
    }
    private int currentPage
    {
        get => Session.OrganizerCurrentPage;
        set => Session.OrganizerCurrentPage = value;
    }
    private const int pageSize = 10;

    private List<User> FilteredOrganizers => (pendingOrganizers ?? new List<User>())
        .Where(u => string.IsNullOrWhiteSpace(searchTerm) ||
                    (u.UserName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (u.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    private List<User> PagedOrganizers => FilteredOrganizers
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredOrganizers.Count / (double)pageSize);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Yield();
        LoadData();
        StateHasChanged();
    }

    private void LoadData()
    {
        try
        {
            var allUsers = UserService.GetAllUsers();
            // Role 2 = Organizer
            allOrganizers = allUsers.Where(u => u.Role == 2).ToList();
            // Status 0 = Pending
            pendingOrganizers = allOrganizers.Where(u => u.Status == 0).ToList();
        }
        catch (Exception ex)
        {
            alert?.Show($"Failed to load organizer data: {ex.Message}", true);
            pendingOrganizers = new List<User>();
            allOrganizers = new List<User>();
        }
    }

    private void Approve(User user)
    {
        var captured = user;
        pendingAction = async () =>
        {
            // B.E validation via UserService
            var result = UserService.ApproveOrganizer(captured.Id);
            if (!result.Success)
            {
                alert?.Show(result.Error ?? "Failed to approve organizer.", true);
                return;
            }
            LoadData();
            Session.NotifyCountsChanged();
            alert?.Show($"Organizer '{captured.UserName}' has been approved successfully.");
        };
        confirmModal.Show(
            "Approve Organizer",
            $"Approve '{user.UserName}'? They will be able to create and manage events.",
            "Approve", "success");
    }

    private void Reject(User user)
    {
        var captured = user;
        pendingAction = async () =>
        {
            // B.E validation via UserService
            var result = UserService.RejectOrganizer(captured.Id);
            if (!result.Success)
            {
                alert?.Show(result.Error ?? "Failed to reject organizer.", true);
                return;
            }
            LoadData();
            Session.NotifyCountsChanged();
            alert?.Show($"Registration for '{captured.UserName}' was rejected.");
        };
        confirmModal.Show(
            "Reject Organizer",
            $"Reject '{user.UserName}'? Their account will be banned.",
            "Reject", "danger");
    }

    private async Task HandleConfirm()
    {
        if (pendingAction != null)
        {
            await pendingAction();
            pendingAction = null;
        }
    }

    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }
    private void GoToPage(int page) => currentPage = page;
}
