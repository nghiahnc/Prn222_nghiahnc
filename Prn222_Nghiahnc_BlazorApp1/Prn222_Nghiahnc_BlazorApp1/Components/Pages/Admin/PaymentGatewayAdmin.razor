@page "/admin/payment-gateways"
@attribute [Authorize(Roles = "1")]
@using Domain
@using Services
@using Microsoft.JSInterop
@inject IPaymentGatewayConfigService PaymentGatewayConfigService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container-fluid mt-4">
    <div class="card card-modern">
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <h5 class="mb-0"><i class="bi bi-credit-card-fill text-success me-2"></i> Payment Gateway Configurations</h5>
            
            <div class="d-flex">
                <!-- Search -->
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-0 bg-light" placeholder="Search provider..." @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>
        <div class="card-body p-0">

            <AdminAlert @ref="alert" />
            <ConfirmationModal @ref="confirmModal" OnConfirm="HandleConfirm" />

            @if (configs == null)
            {
                <div class="d-flex justify-content-center my-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Provider Name</th>
                                <th>API Key</th>
                                <th>Secret Key</th>
                                <th class="text-center">Active</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedConfigs.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        @(string.IsNullOrWhiteSpace(searchTerm) ? "No payment gateways configured. Add one below." : "No gateways found matching your search.")
                                    </td>
                                </tr>
                            }
                            @foreach (var config in PagedConfigs)
                            {
                                <tr>
                                    <td>
                                        <input type="text" class="form-control form-control-sm rounded-pill px-3" @bind="config.Name" style="max-width: 200px;" />
                                    </td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm rounded-pill px-3" @bind="config.ApiKey" />
                                    </td>
                                    <td>
                                        <input type="password" class="form-control form-control-sm rounded-pill px-3" @bind="config.SecretKey" />
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input" type="checkbox" @bind="config.IsActive" title="Toggle Active Status" />
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-2 rounded-pill px-3" @onclick="() => SaveConfig(config)" title="Save">
                                            <i class="bi bi-save"></i> Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => DeleteConfig(config)" title="Delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Controls -->
                @if (TotalPages > 1)
                {
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center p-3 border-top-0">
                        <span class="text-muted small">Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, FilteredConfigs.Count)) of @FilteredConfigs.Count entries</span>
                        <nav>
                            <ul class="pagination pagination-sm pagination-modern mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                                </li>
                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    int pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }

                <div class="card-footer bg-light p-4">
                    <h6 class="fw-bold mb-3 text-secondary">Add New Gateway Configuration</h6>
                    <EditForm Model="@newConfig" OnValidSubmit="AddConfig">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />

                        <div class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <InputText class="form-control rounded-pill px-3" placeholder="Provider Name (e.g. Stripe)" @bind-Value="newConfig.Name" />
                                <ValidationMessage For="@(() => newConfig.Name)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-3">
                                <InputText class="form-control rounded-pill px-3" placeholder="API Key" @bind-Value="newConfig.ApiKey" />
                                <ValidationMessage For="@(() => newConfig.ApiKey)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-3">
                                <InputText class="form-control rounded-pill px-3" placeholder="Secret Key" @bind-Value="newConfig.SecretKey" type="password" />
                                <ValidationMessage For="@(() => newConfig.SecretKey)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-1 text-center">
                                <div class="form-check form-switch d-flex justify-content-center mb-1">
                                    <InputCheckbox class="form-check-input" @bind-Value="newConfig.IsActive" id="isActiveCheck" />
                                </div>
                                <label class="form-check-label small text-muted" for="isActiveCheck">Active</label>
                            </div>
                            <div class="col-md-2 text-center">
                                <button type="submit" class="btn btn-success rounded-pill px-4 w-100"><i class="bi bi-plus-lg me-1"></i> Add</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<PaymentGatewayConfig>? configs;
    private PaymentGatewayConfig newConfig = new PaymentGatewayConfig();
    private AdminAlert alert = default!;
    private ConfirmationModal confirmModal = default!;
    private Func<Task>? pendingAction;

    // Search
    private string _searchTerm = string.Empty;
    private string searchTerm 
    { 
        get => _searchTerm; 
        set { _searchTerm = value; currentPage = 1; } 
    }

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;

    private List<PaymentGatewayConfig> FilteredConfigs => (configs ?? new List<PaymentGatewayConfig>())
        .Where(c => string.IsNullOrWhiteSpace(searchTerm) || 
                    (c.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    private List<PaymentGatewayConfig> PagedConfigs => FilteredConfigs
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredConfigs.Count / (double)pageSize);

    protected override void OnInitialized()
    {
        LoadConfigs();
    }

    private void LoadConfigs()
    {
        try
        {
            configs = PaymentGatewayConfigService.GetAllConfigs();
        }
        catch (Exception ex)
        {
            alert?.Show($"Failed to load gateway configs: {ex.Message}", true);
        }
    }

    private void SaveConfig(PaymentGatewayConfig config)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(config.Name) || string.IsNullOrWhiteSpace(config.ApiKey) || string.IsNullOrWhiteSpace(config.SecretKey))
            {
                alert?.Show("Provider Name, API Key, and Secret Key are required.", true);
                return;
            }

            PaymentGatewayConfigService.UpdateConfig(config);
            alert?.Show($"Configuration for '{config.Name}' saved successfully.");
        }
        catch (Exception ex)
        {
            alert?.Show($"Error saving configuration: {ex.Message}", true);
        }
    }

    private void AddConfig()
    {
        try
        {
            // Check for duplicate provider name
            if (configs != null && configs.Any(c => c.Name.Equals(newConfig.Name, StringComparison.OrdinalIgnoreCase)))
            {
                alert?.Show($"A gateway configuration for '{newConfig.Name}' already exists.", true);
                return;
            }

            PaymentGatewayConfigService.CreateConfig(newConfig);
            newConfig = new PaymentGatewayConfig(); // Reset form
            LoadConfigs();
            alert?.Show("New payment gateway configuration added successfully.");
        }
        catch (Exception ex)
        {
            alert?.Show($"Error adding configuration: {ex.Message}", true);
        }
    }

    private void DeleteConfig(PaymentGatewayConfig config)
    {
        pendingAction = async () =>
        {
            try
            {
                PaymentGatewayConfigService.DeleteConfig(config.Id);
                LoadConfigs();
                alert?.Show("Configuration deleted successfully.");
            }
            catch (Exception ex)
            {
                alert?.Show($"Error deleting configuration: {ex.Message}", true);
            }
        };
        confirmModal.Show("Delete Configuration", $"Are you sure you want to delete the configuration for '{config.Name}'?", "Delete", "danger");
    }

    private async Task HandleConfirm()
    {
        if (pendingAction != null)
        {
            await pendingAction();
            pendingAction = null;
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void GoToPage(int pageNum)
    {
        currentPage = pageNum;
    }
}
