@page "/admin/system-settings"
@attribute [Authorize(Roles = "1")]
@using Domain
@using Services
@using Microsoft.JSInterop
@inject ISystemSettingService SystemSettingService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container-fluid mt-4">
    <div class="card card-modern">
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <h5 class="mb-0"><i class="bi bi-gear-fill text-secondary me-2"></i> System Settings</h5>
            
            <div class="d-flex">
                <!-- Search -->
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-0 bg-light" placeholder="Search by key..." @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            
            <AdminAlert @ref="alert" />
            <ConfirmationModal @ref="confirmModal" OnConfirm="HandleConfirm" />

            @if (settings == null)
            {
                <div class="d-flex justify-content-center my-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Key</th>
                                <th>Value</th>
                                <th>Description</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedSettings.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">
                                        @(string.IsNullOrWhiteSpace(searchTerm) ? "No system settings found. Add one below." : "No settings found matching your search.")
                                    </td>
                                </tr>
                            }
                            @foreach (var setting in PagedSettings)
                            {
                                <tr>
                                    <td><span class="badge badge-soft-secondary px-3 py-2">@setting.SettingKey</span></td>
                                    <td>
                                        <input type="text" class="form-control form-control-sm rounded-pill px-3" @bind="setting.SettingValue" style="max-width: 300px;" />
                                    </td>
                                    <td class="text-muted" style="font-size: 0.9rem;">@setting.Description</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary me-2 rounded-pill px-3" @onclick="() => SaveSetting(setting)" title="Save">
                                            <i class="bi bi-save"></i> Save
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => DeleteSetting(setting)" title="Delete">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Controls -->
                @if (TotalPages > 1)
                {
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center p-3 border-top-0">
                        <span class="text-muted small">Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, FilteredSettings.Count)) of @FilteredSettings.Count entries</span>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                                </li>
                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    int pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }

                <div class="card-footer bg-light p-4">
                    <h6 class="fw-bold mb-3 text-secondary">Add New Setting</h6>
                    <EditForm Model="@newSetting" OnValidSubmit="AddSetting">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger small" />

                        <div class="row g-3 align-items-center">
                            <div class="col-md-3">
                                <InputText class="form-control rounded-pill px-3" placeholder="Key (e.g., SiteName)" @bind-Value="newSetting.SettingKey" />
                                <ValidationMessage For="@(() => newSetting.SettingKey)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-3">
                                <InputText class="form-control rounded-pill px-3" placeholder="Value" @bind-Value="newSetting.SettingValue" />
                                <ValidationMessage For="@(() => newSetting.SettingValue)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-4">
                                <InputText class="form-control rounded-pill px-3" placeholder="Optional description" @bind-Value="newSetting.Description" />
                                <ValidationMessage For="@(() => newSetting.Description)" class="text-danger small mt-1" />
                            </div>
                            <div class="col-md-2 text-center">
                                <button type="submit" class="btn btn-success rounded-pill px-4 w-100"><i class="bi bi-plus-lg me-1"></i> Add</button>
                            </div>
                        </div>
                    </EditForm>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<SystemSetting>? settings;
    private SystemSetting newSetting = new SystemSetting();
    private AdminAlert alert = default!;
    private ConfirmationModal confirmModal = default!;
    private Func<Task>? pendingAction;

    // Search
    private string _searchTerm = string.Empty;
    private string searchTerm 
    { 
        get => _searchTerm; 
        set { _searchTerm = value; currentPage = 1; } 
    }

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;

    private List<SystemSetting> FilteredSettings => (settings ?? new List<SystemSetting>())
        .Where(s => string.IsNullOrWhiteSpace(searchTerm) || 
                    (s.SettingKey?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    private List<SystemSetting> PagedSettings => FilteredSettings
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredSettings.Count / (double)pageSize);

    protected override void OnInitialized()
    {
        LoadSettings();
    }

    private void LoadSettings()
    {
        try
        {
            settings = SystemSettingService.GetAllSettings();
        }
        catch (Exception ex)
        {
            alert?.Show($"Failed to load settings: {ex.Message}", true);
        }
    }

    private void SaveSetting(SystemSetting setting)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(setting.SettingValue))
            {
                alert?.Show("Setting Value cannot be empty.", true);
                return;
            }
            
            SystemSettingService.UpdateSetting(setting);
            alert?.Show($"Setting '{setting.SettingKey}' updated successfully.");
        }
        catch (Exception ex)
        {
            alert?.Show($"Error updating setting: {ex.Message}", true);
        }
    }

    private void AddSetting()
    {
        try
        {
            // Check for duplicate key
            if (settings != null && settings.Any(s => s.SettingKey.Equals(newSetting.SettingKey, StringComparison.OrdinalIgnoreCase)))
            {
                alert?.Show($"The key '{newSetting.SettingKey}' already exists.", true);
                return;
            }

            SystemSettingService.CreateSetting(newSetting);
            newSetting = new SystemSetting(); // Reset form
            LoadSettings();
            alert?.Show("New setting added successfully.");
        }
        catch (Exception ex)
        {
            alert?.Show($"Error adding setting: {ex.Message}", true);
        }
    }

    private void DeleteSetting(SystemSetting setting)
    {
        pendingAction = async () =>
        {
            try
            {
                SystemSettingService.DeleteSetting(setting.Id);
                LoadSettings();
                alert?.Show("Setting deleted successfully.");
            }
            catch (Exception ex)
            {
                alert?.Show($"Error deleting setting: {ex.Message}", true);
            }
        };
        confirmModal.Show("Delete Setting", $"Are you sure you want to delete the setting '{setting.SettingKey}'?", "Delete", "danger");
    }

    private async Task HandleConfirm()
    {
        if (pendingAction != null)
        {
            await pendingAction();
            pendingAction = null;
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void GoToPage(int pageNum)
    {
        currentPage = pageNum;
    }
}
