@page "/admin/transaction-disputes"
@attribute [Authorize(Roles = "1")]
@using Domain
@using Services
@using Microsoft.JSInterop
@inject ITransactionService TransactionService
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<div class="container-fluid mt-4">
    <div class="card card-modern">
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <h5 class="mb-0"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i> Process Transaction Disputes</h5>
            
            <div class="d-flex">
                <!-- Search -->
                <div class="input-group input-group-sm" style="width: 250px;">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-0 bg-light" placeholder="Search ID or Username..." @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>
        <div class="card-body p-0">

            <AdminAlert @ref="alert" />
            <ConfirmationModal @ref="confirmModal" OnConfirm="HandleConfirm" />

            @if (disputedTransactions == null)
            {
                <div class="d-flex justify-content-center my-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (disputedTransactions.Count == 0 && string.IsNullOrWhiteSpace(searchTerm))
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-shield-check display-1 text-success mb-3"></i>
                    <h4>No active disputes</h4>
                    <p>There are currently no transaction disputes to process. Everything looks good!</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Transaction ID</th>
                                <th>Customer (User ID)</th>
                                <th>Dispute Details</th>
                                <th>Status</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedDisputes.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">No disputes found matching your search.</td>
                                </tr>
                            }
                            @foreach (var transaction in PagedDisputes)
                            {
                                <tr>
                                    <td class="text-muted fw-bold">#@transaction.Id</td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-placeholder bg-secondary bg-opacity-10 text-secondary">
                                                <i class="bi bi-person"></i>
                                            </div>
                                            <span class="fw-semibold">@(transaction.User?.UserName ?? $"User {transaction.UserId}")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="text-break mb-0 text-muted" style="max-width: 400px; font-size: 0.9rem;">@transaction.Detail</p>
                                    </td>
                                    <td>
                                        <span class="badge badge-soft-warning"><i class="bi bi-exclamation-circle"></i> In Dispute</span>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-success me-2 rounded-pill px-3" @onclick="() => Resolve(transaction, 4, true)" title="Approve Refund">
                                            <i class="bi bi-currency-dollar"></i> Approve Refund
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" @onclick="() => Resolve(transaction, 5, false)" title="Reject Dispute">
                                            <i class="bi bi-x-circle"></i> Reject Dispute
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination Controls -->
                @if (TotalPages > 1)
                {
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center p-3 border-top-0">
                        <span class="text-muted small">Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, FilteredDisputes.Count)) of @FilteredDisputes.Count entries</span>
                        <nav>
                            <ul class="pagination pagination-sm pagination-modern mb-0">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <button class="page-link" @onclick="PrevPage"><i class="bi bi-chevron-left"></i></button>
                                </li>
                                @for (int i = 1; i <= TotalPages; i++)
                                {
                                    int pageNum = i;
                                    <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                                    </li>
                                }
                                <li class="page-item @(currentPage == TotalPages ? "disabled" : "")">
                                    <button class="page-link" @onclick="NextPage"><i class="bi bi-chevron-right"></i></button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<Transaction>? disputedTransactions;
    private AdminAlert alert = default!;
    private ConfirmationModal confirmModal = default!;
    private Func<Task>? pendingAction;

    // Search
    private string _searchTerm = string.Empty;
    private string searchTerm 
    { 
        get => _searchTerm; 
        set { _searchTerm = value; currentPage = 1; } 
    }

    // Pagination
    private int currentPage = 1;
    private int pageSize = 10;

    private List<Transaction> FilteredDisputes => (disputedTransactions ?? new List<Transaction>())
        .Where(t => string.IsNullOrWhiteSpace(searchTerm) || 
                    t.Id.ToString().Contains(searchTerm) ||
                    (t.User?.UserName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    private List<Transaction> PagedDisputes => FilteredDisputes
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredDisputes.Count / (double)pageSize);

    protected override void OnInitialized()
    {
        LoadDisputes();
    }

    private void LoadDisputes()
    {
        try
        {
            // Assuming Status 3 means Dispute
            disputedTransactions = TransactionService.GetAllTransactions().Where(t => t.Status == 3).ToList();
        }
        catch (Exception ex)
        {
            alert?.Show($"Failed to load transaction disputes: {ex.Message}", true);
        }
    }

    private void Resolve(Transaction transaction, int newStatus, bool isRefund)
    {
        string actionName = isRefund ? "approve a refund" : "reject the dispute";
        string title = isRefund ? "Approve Refund" : "Reject Dispute";
        string color = isRefund ? "success" : "danger";
        string buttonText = isRefund ? "Approve Refund" : "Reject Dispute";

        pendingAction = async () =>
        {
            try
            {
                // Status 4 = Refunded, Status 5 = Dispute Rejected
                transaction.Status = newStatus;
                TransactionService.UpdateTransaction(transaction);
                LoadDisputes();
                
                if (isRefund)
                {
                    alert?.Show($"Refund approved successfully for Transaction #{transaction.Id}.");
                }
                else
                {
                    alert?.Show($"Dispute rejected for Transaction #{transaction.Id}.", true);
                }
            }
            catch (Exception ex)
            {
                alert?.Show($"Error processing dispute: {ex.Message}", true);
            }
        };

        confirmModal.Show(title, $"Are you sure you want to {actionName} for Transaction #{transaction.Id}?", buttonText, color);
    }

    private async Task HandleConfirm()
    {
        if (pendingAction != null)
        {
            await pendingAction();
            pendingAction = null;
        }
    }

    private void PrevPage()
    {
        if (currentPage > 1) currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void GoToPage(int pageNum)
    {
        currentPage = pageNum;
    }
}
