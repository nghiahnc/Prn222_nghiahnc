@page "/admin/transaction-disputes"
@attribute [Authorize(Roles = "1")]
@using Domain
@using global::Services
@inject ITransactionService TransactionService
@inject Prn222_Nghiahnc_BlazorApp1.Services.AdminSessionService Session
@rendermode InteractiveServer

<PageTitle>Transaction Disputes — Admin Portal</PageTitle>

<div class="container-fluid">

    <!-- Page Title -->
    <div class="page-title-section">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="admin/accounts">Dashboard</a></li>
                <li class="breadcrumb-item active">Transaction Disputes</li>
            </ol>
        </nav>
        <h4><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Process Transaction Disputes</h4>
        <p>Review and resolve transaction disputes raised by users. Approve refunds or reject invalid claims.</p>
    </div>

    <!-- Summary Stats -->
    @if (allTransactions != null)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon amber">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allTransactions.Count(t => t.Status == 3))</h3>
                        <small>Open Disputes</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon green">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allTransactions.Count(t => t.Status == 4))</h3>
                        <small>Refunds Approved</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon red">
                        <i class="bi bi-x-circle-fill"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@(allTransactions.Count(t => t.Status == 5))</h3>
                        <small>Disputes Rejected</small>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-card-icon blue">
                        <i class="bi bi-receipt"></i>
                    </div>
                    <div class="stat-card-body">
                        <h3>@allTransactions.Count</h3>
                        <small>Total Transactions</small>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Main Card -->
    <div class="card card-modern">
        <!-- Header + Filters -->
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <h5 class="mb-0">
                <i class="bi bi-exclamation-circle text-warning me-2"></i>
                Dispute Queue
                @if (disputedTransactions != null && disputedTransactions.Count > 0)
                {
                    <span class="badge rounded-pill ms-2"
                          style="background:#f59e0b;color:white;font-size:.65rem;vertical-align:middle;">
                        @disputedTransactions.Count
                    </span>
                }
            </h5>
            <div class="d-flex flex-wrap gap-2">
                <div class="input-group input-group-sm" style="width:260px;">
                    <span class="input-group-text bg-light border-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" class="form-control border-0 bg-light"
                           placeholder="Search transaction ID or username..."
                           @bind="searchTerm" @bind:event="oninput" />
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <button class="input-group-text bg-light border-0 btn p-0 pe-2"
                                @onclick="() => searchTerm = string.Empty">
                            <i class="bi bi-x text-muted"></i>
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Alert + Confirm -->
        <AdminAlert @ref="alert" />
        <ConfirmationModal @ref="confirmModal" OnConfirm="HandleConfirm" />

        <!-- Content -->
        <div class="card-body p-0">
            @if (disputedTransactions == null)
            {
                <div class="loading-container">
                    <div class="spinner-modern"></div>
                    <span>Loading disputes...</span>
                </div>
            }
            else if (FilteredDisputes.Count == 0)
            {
                <div class="empty-state">
                    @if (string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <div class="display-icon text-success">
                            <i class="bi bi-shield-check-fill"></i>
                        </div>
                        <h5>No Active Disputes</h5>
                        <p>There are currently no pending transaction disputes to process. Everything looks good!</p>
                    }
                    else
                    {
                        <div class="display-icon">
                            <i class="bi bi-search"></i>
                        </div>
                        <h5>No Results Found</h5>
                        <p>No disputes found matching "<strong>@searchTerm</strong>".</p>
                        <button class="btn btn-outline-primary btn-sm rounded-pill mt-2"
                                @onclick="() => searchTerm = string.Empty">
                            Clear Search
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-modern">
                        <thead>
                            <tr>
                                <th>Txn ID</th>
                                <th>Customer</th>
                                <th>Dispute Description</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var transaction in PagedDisputes)
                            {
                                <tr>
                                    <td>
                                        <span class="fw-bold" style="font-size:.875rem;">
                                            <i class="bi bi-hash text-muted" style="font-size:.75rem;"></i>@transaction.Id
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-placeholder bg-secondary">
                                                <i class="bi bi-person" style="font-size:.85rem;"></i>
                                            </div>
                                            <div>
                                                <div class="fw-semibold" style="font-size:.875rem;">
                                                    @(transaction.User?.UserName ?? "Unknown User")
                                                </div>
                                                <div style="font-size:.72rem;color:#9ca3af;">
                                                    User ID: @transaction.UserId
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <p class="text-break mb-0"
                                           style="max-width:380px;font-size:.84rem;color:#6b7280;line-height:1.5;">
                                            @(string.IsNullOrWhiteSpace(transaction.Detail)
                                                ? "No description provided."
                                                : transaction.Detail)
                                        </p>
                                    </td>
                                    <td>
                                        <span class="badge-soft-warning">
                                            <i class="bi bi-exclamation-circle me-1"></i>In Dispute
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                                            <button class="btn btn-sm btn-outline-success rounded-pill px-3"
                                                    @onclick="() => ApproveRefund(transaction)"
                                                    title="Approve Refund — mark as refunded">
                                                <i class="bi bi-currency-dollar me-1"></i>Approve Refund
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                                    @onclick="() => RejectDispute(transaction)"
                                                    title="Reject — dismiss this dispute">
                                                <i class="bi bi-x-circle me-1"></i>Reject
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->                <AdminPagination CurrentPage="currentPage" TotalPages="TotalPages" TotalCount="FilteredDisputes.Count" PageSize="pageSize" EntityName="disputes" OnPageChanged="GoToPage" />
            }
        </div>
    </div>

</div>

@code {
    private List<Transaction>? allTransactions;
    private List<Transaction>? disputedTransactions;
    private AdminAlert alert = default!;
    private ConfirmationModal confirmModal = default!;
    private Func<Task>? pendingAction;

    private string searchTerm
    {
        get => Session.DisputeSearchTerm;
        set { Session.DisputeSearchTerm = value; currentPage = 1; }
    }

    private int currentPage
    {
        get => Session.DisputeCurrentPage;
        set => Session.DisputeCurrentPage = value;
    }

    private const int pageSize = 10;

    private List<Transaction> FilteredDisputes => (disputedTransactions ?? new List<Transaction>())
        .Where(t => string.IsNullOrWhiteSpace(searchTerm) ||
                    t.Id.ToString().Contains(searchTerm) ||
                    (t.User?.UserName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (t.Detail?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList();

    private List<Transaction> PagedDisputes => FilteredDisputes
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        .ToList();

    private int TotalPages => (int)Math.Ceiling(FilteredDisputes.Count / (double)pageSize);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Task.Yield();
        LoadDisputes();
        StateHasChanged();
    }

    private void LoadDisputes()
    {
        try
        {
            allTransactions = TransactionService.GetAllTransactions();
            // Status 3 = In Dispute
            disputedTransactions = allTransactions.Where(t => t.Status == 3).ToList();
        }
        catch (Exception ex)
        {
            alert?.Show($"Failed to load transaction disputes: {ex.Message}", true);
            disputedTransactions = new List<Transaction>();
            allTransactions = new List<Transaction>();
        }
    }

    private void ApproveRefund(Transaction tx)
    {
        var captured = tx;
        pendingAction = async () =>
        {
            // B.E validation via TransactionService
            var result = TransactionService.ResolveDispute(captured.Id, 4);
            if (!result.Success)
            {
                alert?.Show(result.Error ?? "Failed to process dispute.", true);
                return;
            }
            LoadDisputes();
            Session.NotifyCountsChanged();
            alert?.Show($"Refund approved for Transaction #{captured.Id}. Status updated to Refunded.");
        };
        confirmModal.Show(
            "Approve Refund",
            $"Approve refund for Transaction #{tx.Id}? Funds will be returned to the customer.",
            "Approve Refund", "success");
    }

    private void RejectDispute(Transaction tx)
    {
        var captured = tx;
        pendingAction = async () =>
        {
            // B.E validation via TransactionService
            var result = TransactionService.ResolveDispute(captured.Id, 5);
            if (!result.Success)
            {
                alert?.Show(result.Error ?? "Failed to process dispute.", true);
                return;
            }
            LoadDisputes();
            Session.NotifyCountsChanged();
            alert?.Show($"Dispute for Transaction #{captured.Id} was rejected. Status updated to Dispute Rejected.");
        };
        confirmModal.Show(
            "Reject Dispute",
            $"Reject the dispute for Transaction #{tx.Id}? The original charge will stand.",
            "Reject Dispute", "warning");
    }

    private async Task HandleConfirm()
    {
        if (pendingAction != null)
        {
            await pendingAction();
            pendingAction = null;
        }
    }

    private void PrevPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < TotalPages) currentPage++; }
    private void GoToPage(int page) => currentPage = page;
}
