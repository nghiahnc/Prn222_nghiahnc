@model BookingDetailsViewModel

@{
    ViewData["Title"] = "Booking Details";
    var booking = Model.Details.Booking;
}

<div class="mb-3">
    <a asp-controller="Bookings" asp-action="Index" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

<h1 class="h3">Booking #@booking.Id</h1>

@if (!string.IsNullOrWhiteSpace(TempData["Error"] as string))
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!string.IsNullOrWhiteSpace(TempData["Message"] as string))
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<dl class="row mt-4">
    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@booking.CreatedAt.ToString("f")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@CustomerLabels.BookingStatus(booking.Status)</dd>

    <dt class="col-sm-3">Payment</dt>
    <dd class="col-sm-9">@booking.Transaction?.Detail</dd>

    <dt class="col-sm-3">Payment Status</dt>
    <dd class="col-sm-9">@CustomerLabels.PaymentStatus(booking.Transaction?.Status ?? -1)</dd>
</dl>

@if (Model.Details.CanConfirmPayment)
{
    <form method="post" asp-controller="Bookings" asp-action="ConfirmPayment" asp-route-id="@booking.Id" class="mb-4">
        <button class="btn btn-primary" type="submit">Confirm Payment</button>
    </form>
}

<h2 class="h5 mt-4">Tickets</h2>
<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Ticket</th>
                <th>Event</th>
                <th>Type</th>
                <th>Check-in</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ticket in Model.Details.Tickets)
        {
            <tr>
                <td>#@ticket.Id</td>
                <td>@ticket.TicketType?.Event?.Name</td>
                <td>@ticket.TicketType?.Name</td>
                <td>@(ticket.IsCheckedIn ? ticket.CheckInTime?.ToString("g") : "Not checked in")</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(Model.RazorBaseUrl))
                    {
                        <a class="btn btn-sm btn-outline-primary" href="@($"{Model.RazorBaseUrl}/Tickets/Qr/{ticket.Id}")">QR</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.Details.Tickets.Any())
{
    <div class="alert alert-info">Ticket will be issued after the transaction is confirmed.</div>
}
