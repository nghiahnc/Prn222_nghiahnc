@model Domain.Event
@{
    ViewData["Title"] = "Cancel Event";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4>Cancel Event: @Model.Name</h4>
            </div>
            <div class="card-body">
                <p class="lead text-danger">Are you sure you want to cancel this event?</p>
                <p>This action will set the event status to Cancelled. 
                   It cannot be undone, and the event will no longer be active.</p>
                   
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-flex justify-content-end mt-4">
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary me-2">Back to Details</a>
                        <button type="submit" class="btn btn-danger">Yes, Cancel Event</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
