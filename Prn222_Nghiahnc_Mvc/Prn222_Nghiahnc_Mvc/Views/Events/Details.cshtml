@model Domain.Event
@inject MVC.Data2.DemoMVC2Context DbContext
@{
    ViewData["Title"] = Model.Name;
    var role = Context.Session.GetInt32("Role");
    var userId = Context.Session.GetInt32("UserId");
    var canManage = role == 0 || (role == 2 && Model.CreatedBy == userId);

    var ticketTypeIds = Model.TicketTypes?.Select(tt => tt.Id).ToList() ?? new List<int>();
    var hasSoldTickets = ticketTypeIds.Any() && DbContext.Ticket.Any(t => ticketTypeIds.Contains(t.TicketTypeId));
    var canDelete = Model.Status != 1 && !hasSoldTickets;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2>@Model.Name</h2>
                    <span>
                        @if (Model.Status == 0) { <span class="badge bg-secondary fs-6">Draft</span> }
                        else if (Model.Status == 2) { <span class="badge bg-danger fs-6">Cancelled</span> }
                        else if (Model.Status == 3 || (Model.Status == 1 && Model.TimeEnd <= DateTime.Now)) { <span class="badge bg-primary fs-6">Completed</span> }
                        else if (Model.Status == 1) { <span class="badge bg-success fs-6">Published</span> }
                    </span>
                </div>
                <hr />
                <p><strong>Category:</strong> @(Model.EventCategory?.Name ?? "Uncategorized")</p>
                <p><strong>Location:</strong> @Model.Location</p>
                <p><strong>Detail:</strong> @Model.Detail</p>
                <p><strong>Start Time:</strong> @Model.TimeStart.ToString("F")</p>
                <p><strong>End Time:</strong> @Model.TimeEnd.ToString("F")</p>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4>Ticket Types</h4>
                    @if (canManage && Model.Status != 2 && Model.TimeStart > DateTime.Now)
                    {
                        <a asp-controller="TicketTypes" asp-action="Index" asp-route-eventId="@Model.Id" class="btn btn-sm btn-outline-primary">Manage Ticket Types</a>
                    }
                </div>
                <hr />
                @if (Model.TicketTypes == null || Model.TicketTypes.Count == 0)
                {
                    <p class="text-muted">No ticket types defined yet.</p>
                }
                else
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tt in Model.TicketTypes)
                            {
                                <tr>
                                    <td>@tt.Name</td>
                                    <td>@tt.Price.ToString("C")</td>
                                    <td>@tt.Quantity</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4>Refund & Cancel Policy</h4>
                    @if (canManage && Model.Status != 2 && Model.TimeStart > DateTime.Now)
                    {
                        <a asp-controller="RefundCancelPolicies" asp-action="Manage" asp-route-eventId="@Model.Id" class="btn btn-sm btn-outline-primary">Configure</a>
                    }
                </div>
                <hr />
                @if (Model.RefundCancelPolicy == null)
                {
                    <p class="text-muted">No policy configured for this event.</p>
                }
                else
                {
                    <p><strong>Allow Refund:</strong> @(Model.RefundCancelPolicy.AllowRefund ? "Yes" : "No")</p>
                    @if (Model.RefundCancelPolicy.AllowRefund)
                    {
                        <p><strong>Refund Before:</strong> @Model.RefundCancelPolicy.RefundBeforeHours Hours</p>
                        <p><strong>Refund Percent:</strong> @Model.RefundCancelPolicy.RefundPercent%</p>
                    }
                    <p><strong>Allow Cancel:</strong> @(Model.RefundCancelPolicy.AllowCancel ? "Yes" : "No")</p>
                    @if (Model.RefundCancelPolicy.AllowCancel)
                    {
                        <p><strong>Cancel Before:</strong> @Model.RefundCancelPolicy.CancelBeforeHours Hours</p>
                    }
                    @if (!string.IsNullOrEmpty(Model.RefundCancelPolicy.PolicyNote))
                    {
                        <p><strong>Notes:</strong> @Model.RefundCancelPolicy.PolicyNote</p>
                    }
                }
            </div>
        </div>

        @if (canManage)
        {
            <div class="card shadow-sm">
                <div class="card-body">
                    <h4>Actions</h4>
                    <hr />
                    <div class="d-grid gap-2">
                        @if (Model.Status == 0)
                        {
                            <form asp-action="Publish" asp-route-id="@Model.Id" method="post" class="d-grid">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">Publish Event</button>
                            </form>
                        }
                        
                        @if (Model.Status != 2)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary">Edit Event</a>
                        }

                        @if (Model.Status != 2 && Model.TimeStart > DateTime.Now)
                        {
                            <a asp-action="Postpone" asp-route-id="@Model.Id" class="btn btn-warning">Postpone Event</a>
                        }

                        @if (Model.Status == 0 || Model.Status == 1)
                        {
                            <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger">Cancel Event</a>
                        }

                        @if (canDelete)
                        {
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete Event</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger" disabled data-bs-toggle="tooltip" data-bs-placement="top" title="Cannot delete event: @(Model.Status == 1 ? "It is already published." : "It has ticket types with sold tickets.")">Delete Event</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
