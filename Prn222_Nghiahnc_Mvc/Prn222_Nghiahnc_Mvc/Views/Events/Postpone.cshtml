@model Prn222_Nghiahnc_Mvc.Models.PostponeEventViewModel
@{
    ViewData["Title"] = "Postpone Event";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h3 class="mb-4">Postpone Event</h3>
                
                <form asp-action="Postpone" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EventId" />
                    <input type="hidden" asp-for="CurrentTimeStart" />
                    <input type="hidden" asp-for="CurrentTimeEnd" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Current Start Time</label>
                        <p>@Model.CurrentTimeStart.ToString("F")</p>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Current End Time</label>
                        <p>@Model.CurrentTimeEnd.ToString("F")</p>
                    </div>
                    
                    <hr />

                    <div class="mb-3">
                        <label asp-for="NewTimeStart" class="form-label">New Start Time</label>
                        <input asp-for="NewTimeStart" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="NewTimeStart" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewTimeEnd" class="form-label">New End Time</label>
                        <input asp-for="NewTimeEnd" type="datetime-local" class="form-control" required />
                        <span asp-validation-for="NewTimeEnd" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Reason" class="form-label">Reason for Postponement (Optional)</label>
                        <textarea asp-for="Reason" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="d-flex justify-content-end">
                        <a asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-secondary me-2">Cancel</a>
                        <button type="submit" class="btn btn-warning">Save New Schedule</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
