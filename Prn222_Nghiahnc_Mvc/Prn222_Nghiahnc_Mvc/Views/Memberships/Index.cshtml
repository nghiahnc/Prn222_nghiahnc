@model List<Domain.Membership>
@{
    ViewData["Title"] = "Memberships List";
}

<h2>Memberships List</h2>
<hr />

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model == null || Model.Count == 0)
        {
            <p class="text-muted mb-0">No memberships found.</p>
        }
        else
        {
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Tier</th>
                        <th>Name</th>
                        <th>Points Requirement</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge bg-info text-dark">@item.Tier</span></td>
                            <td>@item.Name</td>
                            <td>@item.Point</td>
                            <td>@item.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
