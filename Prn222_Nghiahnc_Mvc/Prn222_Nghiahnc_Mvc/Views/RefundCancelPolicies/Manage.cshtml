@model Prn222_Nghiahnc_Mvc.Models.RefundCancelPolicyViewModel
@{
    ViewData["Title"] = "Configure Refund/Cancel Policy";
}

<h2>Configure Refund/Cancel Policy</h2>
<h4>For Event: @Model.Event?.Name</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Manage" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="EventId" />

            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Refund Policy</h5>
                    <div class="form-check form-switch mb-3">
                        <input asp-for="AllowRefund" class="form-check-input" type="checkbox" id="allowRefundSwitch" />
                        <label asp-for="AllowRefund" class="form-check-label" for="allowRefundSwitch">Allow Refunds</label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RefundBeforeHours" class="form-label">Refund Before Hours</label>
                        <input asp-for="RefundBeforeHours" class="form-control" type="number" min="0" />
                        <span asp-validation-for="RefundBeforeHours" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="RefundPercent" class="form-label">Refund Percent (%)</label>
                        <input asp-for="RefundPercent" class="form-control" type="number" min="0" max="100" />
                        <span asp-validation-for="RefundPercent" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Cancellation Policy</h5>
                    <div class="form-check form-switch mb-3">
                        <input asp-for="AllowCancel" class="form-check-input" type="checkbox" id="allowCancelSwitch" />
                        <label asp-for="AllowCancel" class="form-check-label" for="allowCancelSwitch">Allow Cancellations</label>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CancelBeforeHours" class="form-label">Cancel Before Hours</label>
                        <input asp-for="CancelBeforeHours" class="form-control" type="number" min="0" />
                        <span asp-validation-for="CancelBeforeHours" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="PolicyNote" class="form-label">Policy Notes</label>
                <textarea asp-for="PolicyNote" class="form-control" rows="3"></textarea>
                <span asp-validation-for="PolicyNote" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save Policy</button>
            <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
