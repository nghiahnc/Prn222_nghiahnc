@model Prn222_Nghiahnc_Mvc.Models.TicketTypeFormViewModel
@{
    ViewData["Title"] = "Define Ticket Type";
}

<h2>Define Ticket Type</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="EventId" class="form-label">Event</label>
                <select asp-for="EventId" class="form-select" asp-items="@(new SelectList(Model.Events, "Id", "Name", Model.EventId))" required>
                    <option value="">-- Select Event --</option>
                </select>
                <span asp-validation-for="EventId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Ticket Type Name</label>
                <input asp-for="Name" class="form-control" placeholder="e.g. VIP, Regular" required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label">Price</label>
                <input asp-for="Price" class="form-control" type="number" step="1" required />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Quantity" class="form-label">Quantity</label>
                <input asp-for="Quantity" class="form-control" type="number" required />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Define</button>
            <a asp-action="Index" asp-route-eventId="@Model.EventId" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
