@model Domain.TicketType
@{
    ViewData["Title"] = "Ticket Type Details";
}

<h2>Ticket Type Details</h2>
<hr />

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5>@Model.Name</h5>
        <p><strong>Associated Event:</strong> @(Model.Event?.Name ?? $"Event #{Model.EventId}")</p>
        <p><strong>Price:</strong> @Model.Price.ToString("C")</p>
        <p><strong>Quantity:</strong> @Model.Quantity</p>
    </div>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
    <a asp-action="Index" asp-route-eventId="@Model.EventId" class="btn btn-outline-secondary">Back to Event Ticket Types</a>
</div>
