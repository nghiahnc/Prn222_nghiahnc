@model List<Domain.TicketType>
@{
    ViewData["Title"] = "Ticket Types";
    var eventId = ViewBag.EventId as int?;
    var eventName = ViewBag.EventName as string;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Ticket Types @(eventId.HasValue ? $"for Event: {eventName}" : "")</h2>
    <div>
        <a asp-action="Create" asp-route-eventId="@eventId" class="btn btn-primary">Define New Ticket Type</a>
        @if (eventId.HasValue)
        {
            <a asp-controller="Events" asp-action="Details" asp-route-id="@eventId" class="btn btn-outline-secondary">Back to Event Details</a>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (Model == null || Model.Count == 0)
        {
            <p class="text-muted mb-0">No ticket types defined.</p>
        }
        else
        {
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        @if (!eventId.HasValue)
                        {
                            <th>Event</th>
                        }
                        <th>Name</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            @if (!eventId.HasValue)
                            {
                                <td>@(item.Event?.Name ?? $"Event #{item.EventId}")</td>
                            }
                            <td>@item.Name</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>@item.Quantity</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
