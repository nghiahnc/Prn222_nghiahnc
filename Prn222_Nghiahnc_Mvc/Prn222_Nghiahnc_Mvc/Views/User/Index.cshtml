@model List<Domain.User>

<h2>Users List</h2>

<a href="/User/Create">Create New</a>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.UserName</td>
            <td>
                <a href="/User/Edit/@item.Id">Edit</a> |
                <a href="/User/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>