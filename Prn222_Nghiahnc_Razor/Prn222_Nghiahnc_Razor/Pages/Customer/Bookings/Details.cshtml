@page "{id:int}"
@model DetailsModel

@{
    ViewData["Title"] = "Booking Details";
}

<div class="mb-3">
    <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<h1 class="h3">Booking #@Model.Details?.Booking.Id</h1>

@if (Model.Details != null)
{
    <dl class="row mt-4">
        <dt class="col-sm-3">Created</dt>
        <dd class="col-sm-9">@Model.Details.Booking.CreatedAt.ToString("f")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.StatusLabel(Model.Details.Booking.Status)</dd>

        <dt class="col-sm-3">Payment</dt>
        <dd class="col-sm-9">@Model.Details.Booking.Transaction?.Detail</dd>

        <dt class="col-sm-3">Payment Status</dt>
        <dd class="col-sm-9">@Model.PaymentStatusLabel(Model.Details.Booking.Transaction?.Status ?? -1)</dd>
    </dl>

    @if (Model.Details.CanConfirmPayment)
    {
        <form method="post" asp-page-handler="ConfirmPayment" class="mb-4">
            <button class="btn btn-primary" type="submit">Confirm Payment</button>
        </form>
    }

    <h2 class="h5 mt-4">Tickets</h2>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Ticket</th>
                    <th>Event</th>
                    <th>Type</th>
                    <th>Check-in</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ticket in Model.Details.Tickets)
            {
                <tr>
                    <td>#@ticket.Id</td>
                    <td>@ticket.TicketType?.Event?.Name</td>
                    <td>@ticket.TicketType?.Name</td>
                    <td>@(ticket.IsCheckedIn ? ticket.CheckInTime?.ToString("g") : "Not checked in")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-page="/Customer/Tickets/Qr" asp-route-id="@ticket.Id">QR</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    @if (!Model.Details.Tickets.Any())
    {
        <div class="alert alert-info">Ticket will be issued after the transaction is confirmed.</div>
    }
}
