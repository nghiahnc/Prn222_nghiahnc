@page
@model IndexModel

@{
    ViewData["Title"] = "Event Categories";
}

<h1 class="h3 mb-4">Event Categories</h1>

<div class="row g-3">
@foreach (var category in Model.Categories)
{
    <div class="col-md-4">
        <div class="border rounded p-3 h-100">
            <h2 class="h5">@category.Name</h2>
            <p class="text-muted">@category.Description</p>
            <a class="btn btn-sm btn-outline-primary" asp-page="./Details" asp-route-id="@category.Id">View events</a>
        </div>
    </div>
}
</div>

@if (!Model.Categories.Any())
{
    <div class="alert alert-info">No event categories found.</div>
}
