@page "{id:int}"
@model DetailsModel

@{
    ViewData["Title"] = "Event Details";
}

<div class="mb-3">
    <a asp-page="./Index" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<h1 class="h3">@Model.EventItem?.Name</h1>

@if (Model.EventItem != null)
{
    <dl class="row mt-4">
        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.EventItem.EventCategory?.Name</dd>

        <dt class="col-sm-3">Venue</dt>
        <dd class="col-sm-9">@Model.EventItem.Location</dd>

        <dt class="col-sm-3">Start</dt>
        <dd class="col-sm-9">@Model.EventItem.TimeStart.ToString("f")</dd>

        <dt class="col-sm-3">End</dt>
        <dd class="col-sm-9">@Model.EventItem.TimeEnd.ToString("f")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.StatusLabel(Model.EventItem.Status)</dd>

        <dt class="col-sm-3">Detail</dt>
        <dd class="col-sm-9">@Model.EventItem.Detail</dd>
    </dl>
}

<h2 class="h5 mt-4">Ticket Types</h2>
<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Available</th>
                <th>Booking</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ticketType in Model.TicketTypes)
        {
            <tr>
                <td>@ticketType.Name</td>
                <td>@ticketType.Price.ToString("N0") VND</td>
                <td>@ticketType.Quantity</td>
                <td>
                    <form method="post" asp-page-handler="BookTicket" class="row gx-2 gy-1 align-items-center">
                        <input type="hidden" name="ticketTypeId" value="@ticketType.Id" />
                        <div class="col-auto">
                            <input class="form-control form-control-sm" type="number" name="quantity" value="1" min="1" max="10" />
                        </div>
                        <div class="col-auto">
                            <input class="form-control form-control-sm" name="discountCode" placeholder="Code" />
                        </div>
                        <div class="col-auto">
                            <input class="form-control form-control-sm" type="number" name="redeemPoints" value="0" min="0" placeholder="Points" />
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-sm btn-primary" type="submit" disabled="@(ticketType.Quantity <= 0)">Book</button>
                        </div>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

@if (!Model.TicketTypes.Any())
{
    <div class="alert alert-info">No ticket types available.</div>
}
