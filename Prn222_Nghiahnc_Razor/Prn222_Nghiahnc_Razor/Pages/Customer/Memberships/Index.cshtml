@page
@model IndexModel

@{
    ViewData["Title"] = "Membership Tiers";
}

<h1 class="h3 mb-4">Membership Tiers</h1>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead>
            <tr>
                <th>Tier</th>
                <th>Name</th>
                <th>Required Points</th>
                <th>Benefit</th>
                <th>Description</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var tier in Model.Memberships)
        {
            <tr>
                <td>@tier.Tier</td>
                <td>@tier.Name</td>
                <td>@Model.Threshold(tier)</td>
                <td>@Model.Discount(tier)% discount</td>
                <td>@tier.Description</td>
            </tr>
        }
        </tbody>
    </table>
</div>
